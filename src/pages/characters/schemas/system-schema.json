{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/SystemSchemaRead",
  "definitions": {
    "SystemSchemaRead": {
      "type": "object",
      "properties": {
        "id": {
          "type": "number"
        },
        "name": {
          "type": "string"
        },
        "schema": {
          "$ref": "#/definitions/CharacterSchema"
        }
      },
      "required": [
        "id",
        "name",
        "schema"
      ],
      "additionalProperties": false
    },
    "CharacterSchema": {
      "type": "object",
      "properties": {
        "sections": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Section"
          }
        },
        "layout": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "i": {
                "type": "string",
                "description": "Unique identifier for this item"
              },
              "x": {
                "type": "number",
                "description": "X position in grid units (0-indexed from left)"
              },
              "y": {
                "type": "number",
                "description": "Y position in grid units (0-indexed from top)"
              },
              "w": {
                "type": "number",
                "description": "Width in grid units"
              },
              "h": {
                "type": "number",
                "description": "Height in grid units"
              },
              "minW": {
                "type": "number",
                "description": "Minimum width in grid units"
              },
              "minH": {
                "type": "number",
                "description": "Minimum height in grid units"
              },
              "maxW": {
                "type": "number",
                "description": "Maximum width in grid units"
              },
              "maxH": {
                "type": "number",
                "description": "Maximum height in grid units"
              },
              "static": {
                "type": "boolean",
                "description": "If true, item cannot be dragged or resized, and other items will move around it during compaction."
              },
              "isDraggable": {
                "type": "boolean",
                "description": "If false, item cannot be dragged (but may still be resizable). Overrides grid-level isDraggable for this item."
              },
              "isResizable": {
                "type": "boolean",
                "description": "If false, item cannot be resized (but may still be draggable). Overrides grid-level isResizable for this item."
              },
              "resizeHandles": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "s",
                    "w",
                    "e",
                    "n",
                    "sw",
                    "nw",
                    "se",
                    "ne"
                  ],
                  "description": "Axis identifiers for resize handles.\n- Cardinal: 'n', 's', 'e', 'w' (north, south, east, west)\n- Diagonal: 'ne', 'nw', 'se', 'sw'"
                },
                "description": "Which resize handles to show for this item. Overrides grid-level resizeHandles for this item."
              },
              "isBounded": {
                "type": "boolean",
                "description": "If true, item is constrained to the grid container bounds. Overrides grid-level isBounded for this item."
              },
              "moved": {
                "type": "boolean",
                "description": "Internal flag set during drag/resize operations to indicate the item has moved from its original position."
              },
              "constraints": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string",
                      "description": "Constraint identifier for debugging"
                    }
                  },
                  "required": [
                    "name"
                  ],
                  "additionalProperties": false,
                  "description": "Interface for layout constraints.\n\nImplement this interface to create custom position/size constraints. Built-in constraints: gridBounds, minMaxSize, containerBounds, boundedX, boundedY."
                },
                "description": "Per-item layout constraints. Applied in addition to grid-level constraints."
              }
            },
            "required": [
              "i",
              "x",
              "y",
              "w",
              "h"
            ],
            "additionalProperties": false,
            "description": "A single item in the grid layout.\n\nPosition (x, y) is in grid units, not pixels. Size (w, h) is in grid units."
          },
          "description": "A layout is a readonly array of layout items. Layouts should be treated as immutable."
        }
      },
      "required": [
        "sections"
      ],
      "additionalProperties": false
    },
    "Section": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "fields": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Field"
          }
        },
        "layout": {
          "type": "string",
          "enum": [
            "unbound",
            "compact",
            "list"
          ]
        },
        "columns": {
          "type": "number"
        }
      },
      "required": [
        "title",
        "fields"
      ],
      "additionalProperties": false
    },
    "Field": {
      "anyOf": [
        {
          "$ref": "#/definitions/NumberField"
        },
        {
          "$ref": "#/definitions/TextField"
        },
        {
          "$ref": "#/definitions/TextareaField"
        },
        {
          "$ref": "#/definitions/SelectField"
        },
        {
          "$ref": "#/definitions/CheckboxField"
        },
        {
          "$ref": "#/definitions/ArrayField"
        },
        {
          "$ref": "#/definitions/MinMaxField"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": {
              "type": "string",
              "const": "header"
            },
            "key": {
              "type": "string"
            },
            "label": {
              "type": "string"
            },
            "ui": {
              "type": "string",
              "enum": [
                "row",
                "column",
                "compact"
              ]
            },
            "array_col": {
              "type": "number"
            }
          },
          "required": [
            "key",
            "label",
            "type"
          ]
        }
      ]
    },
    "NumberField": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "const": "number"
        },
        "defaultValue": {
          "type": "number"
        },
        "key": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "ui": {
          "type": "string",
          "enum": [
            "row",
            "column",
            "compact"
          ]
        },
        "array_col": {
          "type": "number"
        }
      },
      "required": [
        "key",
        "label",
        "type"
      ]
    },
    "TextField": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "const": "text"
        },
        "defaultValue": {
          "type": "string"
        },
        "key": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "ui": {
          "type": "string",
          "enum": [
            "row",
            "column",
            "compact"
          ]
        },
        "array_col": {
          "type": "number"
        }
      },
      "required": [
        "key",
        "label",
        "type"
      ]
    },
    "TextareaField": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "const": "textarea"
        },
        "defaultValue": {
          "type": "string"
        },
        "key": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "ui": {
          "type": "string",
          "enum": [
            "row",
            "column",
            "compact"
          ]
        },
        "array_col": {
          "type": "number"
        }
      },
      "required": [
        "key",
        "label",
        "type"
      ]
    },
    "SelectField": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "const": "select"
        },
        "options": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "defaultValue": {
          "type": "string"
        },
        "key": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "ui": {
          "type": "string",
          "enum": [
            "row",
            "column",
            "compact"
          ]
        },
        "array_col": {
          "type": "number"
        }
      },
      "required": [
        "key",
        "label",
        "options",
        "type"
      ]
    },
    "CheckboxField": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "const": "checkbox"
        },
        "defaultValue": {
          "type": "boolean"
        },
        "key": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "ui": {
          "type": "string",
          "enum": [
            "row",
            "column",
            "compact"
          ]
        },
        "array_col": {
          "type": "number"
        }
      },
      "required": [
        "key",
        "label",
        "type"
      ]
    },
    "ArrayField": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "const": "array"
        },
        "itemSchema": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Field"
          }
        },
        "defaultValue": {
          "type": "array",
          "items": {}
        },
        "key": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "ui": {
          "type": "string",
          "enum": [
            "row",
            "column",
            "compact"
          ]
        },
        "array_col": {
          "type": "number"
        }
      },
      "required": [
        "itemSchema",
        "key",
        "label",
        "type"
      ]
    },
    "MinMaxField": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "const": "minmax"
        },
        "defaultValue": {
          "type": "number"
        },
        "key": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "ui": {
          "type": "string",
          "enum": [
            "row",
            "column",
            "compact"
          ]
        },
        "array_col": {
          "type": "number"
        }
      },
      "required": [
        "key",
        "label",
        "type"
      ]
    }
  }
}